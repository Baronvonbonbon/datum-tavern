# Copy to .env and fill in.

# ── Tavern contract deploy (scripts/deploy.ts) ──────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...
PASEO_RPC_URL=https://eth-rpc-testnet.polkadot.io/
HOUSE_FUND_PAS=100

# ── Datum seeding (scripts/seed-tavern.mjs, Phase 1) ────────────────────────
# Use the Datum test accounts (see datum/alpha-core/scripts/reseed-demo.mjs):
ALICE_KEY=0x...            # owner / admin / funder (Datum Alice)
ADVERTISER_KEY=0x...       # advertiser, already staked (Datum Bob)
# New tavern publisher EOA. Omit on first run to auto-generate one, then paste
# the printed key here so re-runs reuse the same publisher (idempotent).
TAVERN_PUBLISHER_KEY=
# relaySigner the publisher delegates to (the live relay's signing key). Default
# is the live "Diana" relay address; override only if your relay uses another.
DIANA_ADDR=0xcA5668fB864Acab0aC7f4CFa73949174720b58D0
# Path to the Datum repo's deployed addresses (single source of truth).
DATUM_ADDRESSES=../datum/alpha-core/deployed-addresses.json
# Number of fantasy-merchant campaigns to seed (default 5).
CAMPAIGNS=5
TESTNET_RPC=https://eth-rpc-testnet.polkadot.io/
# Action-verifier ADDRESS for type-2 (sponsored-action) claims. Must equal the
# address of the relay's ACTION_VERIFIER_KEY. Leave at zero to fund action pots
# without making them claimable.
ACTION_VERIFIER_ADDR=0x0000000000000000000000000000000000000000
