  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "hardhat": "^2.22.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
